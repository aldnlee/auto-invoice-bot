---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Interactive Invoice Builder</title>
</head>
<body class="bg-slate-100 text-slate-800 min-h-screen p-4 md:p-8">

  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">
    
    <div class="lg:col-span-5 bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col justify-between gap-4 h-fit">
      <div>
        <h2 class="text-xl font-bold text-slate-900">Invoice Editor</h2>
        <p class="text-xs text-slate-500 mt-0.5">Ubah data di bawah untuk memperbarui live preview secara instan.</p>
        
        <hr class="border-slate-100 my-4" />

        <div class="space-y-4">
          <div class="p-3 bg-blue-50/50 border border-blue-100/70 rounded-xl space-y-3">
            <span class="block text-xs font-bold uppercase text-blue-700 tracking-wider">Detail Penerbit (Anda)</span>
            <div class="grid grid-cols-2 gap-2">
              <div>
                <label class="block text-[10px] font-semibold uppercase text-slate-500 mb-0.5">Nama / Perusahaan</label>
                <input type="text" id="inputMyName" value="Alden Lee" class="w-full bg-white border border-slate-200 rounded-lg p-2 text-xs focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
              </div>
              <div>
                <label class="block text-[10px] font-semibold uppercase text-slate-500 mb-0.5">Profesi / Sub-detail</label>
                <input type="text" id="inputMyProf" value="Tech-Creative Professional" class="w-full bg-white border border-slate-200 rounded-lg p-2 text-xs focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold uppercase text-slate-500 mb-1">Nomor Invoice</label>
              <input type="text" id="inputInvoiceNum" value="#INV-73892" class="w-full border border-slate-200 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase text-slate-500 mb-1">Nama Client</label>
              <input type="text" id="inputClient" value="PT. Maju Mundur" class="w-full border border-slate-200 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
            </div>
          </div>

          <div>
            <label class="block text-xs font-semibold uppercase text-slate-500 mb-1">Pilih Tanggal Invoice</label>
            <input type="date" id="inputDate" class="w-full border border-slate-200 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
          </div>

          <div>
            <label class="block text-xs font-semibold uppercase text-slate-500 mb-1">Upload Logo Invoice (Sementara)</label>
            <div class="flex items-center gap-3">
              <input type="file" id="inputLogo" accept="image/*" class="w-full text-xs text-slate-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-600 hover:file:bg-blue-100 transition cursor-pointer" />
              <button type="button" id="btnResetLogo" class="hidden text-xs text-red-500 hover:text-red-700 font-medium cursor-pointer">Hapus</button>
            </div>
            <p class="text-[10px] text-slate-400 mt-1">*Logo akan kembali ke default jika halaman di-refresh.</p>
          </div>

          <div>
            <div class="flex justify-between items-center mb-2">
              <label class="block text-xs font-bold uppercase text-slate-400 tracking-wider">Daftar Item / Layanan</label>
              <button id="btnAddItem" type="button" class="text-xs bg-blue-50 hover:bg-blue-100 text-blue-600 font-bold py-1 px-2.5 rounded-lg transition cursor-pointer">
                ➕ Tambah Item
              </button>
            </div>
            <div id="itemsContainer" class="space-y-3 max-h-[200px] overflow-y-auto pr-1"></div>
          </div>

          <hr class="border-slate-100 my-2" />

          <div class="grid grid-cols-2 gap-3 p-3 bg-slate-50 rounded-xl border border-slate-200/60">
            <div>
              <label class="block text-xs font-semibold uppercase text-slate-500 mb-1">Tipe Admin</label>
              <select id="selectAdminType" class="w-full bg-white border border-slate-200 rounded-lg p-2 text-xs focus:outline-none focus:ring-2 focus:ring-blue-500 transition cursor-pointer font-medium">
                <option value="percent">Persentase (%)</option>
                <option value="fixed">Nominal Kustom (Rp)</option>
              </select>
            </div>
            <div>
              <label id="labelAdminInput" class="block text-xs font-semibold uppercase text-slate-500 mb-1">Biaya Admin (%)</label>
              <input type="number" id="inputAdminValue" value="2.5" min="0" step="0.1" class="w-full bg-white border border-slate-200 rounded-lg p-2 text-xs focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
            </div>
          </div>

        </div>
      </div>

      <div class="pt-4 border-t border-slate-100">
        <button id="btnDownload" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-xl transition duration-200 flex items-center justify-center gap-2 shadow-sm cursor-pointer">
          💾 Download PDF Invoice
        </button>
      </div>
    </div>

    <div class="lg:col-span-7 flex flex-col gap-4">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Live Preview Canvas</span>
      
      <div id="invoiceCanvas" class="bg-white p-12 rounded-xl shadow-md border border-slate-200 aspect-[1/1.414] w-full flex flex-col justify-between font-sans">
        
        <div>
          <div class="flex justify-between items-start border-b border-slate-100 pb-8 mb-8">
            <div>
              <h1 class="text-3xl font-black tracking-tight text-slate-900">INVOICE</h1>
              <p class="text-xs text-slate-400 font-mono mt-1" id="viewInvoiceNum">#INV-73892</p>
            </div>
            <div class="flex flex-col items-end text-right">
              <img 
                id="viewLogo"
                src="/aldn.prjpp.png" 
                alt="Logo Company" 
                class="h-12 w-auto object-contain mb-1 max-w-[160px]" 
                crossorigin="anonymous"
              />
              <h3 class="font-bold text-slate-800 text-sm" id="viewMyName">Alden Lee</h3>
              <p class="text-xs text-slate-400" id="viewMyProf">Tech-Creative Professional</p>
            </div>
          </div>

          <div class="mb-10">
            <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Ditagihkan Kepada:</h4>
            <p id="viewClient" class="text-base font-bold text-slate-700">PT. Maju Mundur</p>
            <p id="viewDate" class="text-xs text-slate-400 mt-1">Tanggal: -</p>
          </div>

          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b-2 border-slate-100 text-xs font-bold uppercase text-slate-400 tracking-wider">
                <th class="pb-3 w-7/12">Deskripsi Event / Layanan</th>
                <th class="pb-3 text-center w-1/12">Qty</th>
                <th class="pb-3 text-right w-2/12">Harga Satuan</th>
                <th class="pb-3 text-right w-2/12">Total</th>
              </tr>
            </thead>
            <tbody id="invoiceTableBody" class="divide-y divide-slate-100 text-sm text-slate-700"></tbody>
          </table>
        </div>

        <div class="border-t border-slate-100 pt-6 flex flex-col items-end gap-2">
          <div class="flex gap-12 text-sm">
            <span class="text-slate-400 font-medium">Subtotal:</span>
            <span id="subTotal" class="text-slate-700 font-semibold">Rp 0</span>
          </div>
          <div class="flex gap-12 text-sm">
            <span class="text-slate-400 font-medium" id="labelAdmin">Biaya Admin (2.5%):</span>
            <span id="viewAdminFee" class="text-slate-700 font-semibold">Rp 0</span>
          </div>
          <div class="flex gap-12 text-base border-t border-dashed border-slate-200 pt-2 mt-1">
            <span class="text-slate-900 font-bold">Total Tagihan:</span>
            <span id="finalTotal" class="text-xl font-black text-blue-600">Rp 0</span>
          </div>

          <div class="border-t border-slate-200 pt-4 mt-2 w-full flex flex-col items-end gap-1">
            <div class="flex gap-4 text-xs">
              <span class="text-slate-400 font-medium">Bank Transfer:</span>
              <span class="text-slate-700 font-semibold">ALDEN LEE - Mandiri</span>
            </div>
            <div class="flex gap-4 text-xs items-center">
              <span class="text-slate-400 font-medium">Bank Number:</span>
              <div class="flex items-center gap-1.5 relative group/copy">
                <span id="viewBankNumber" class="text-slate-700 font-semibold tracking-wider">1330026558106</span>
                <button type="button" id="btnCopyBank" class="ignore-pdf text-slate-400 hover:text-blue-600 transition p-0.5 rounded hover:bg-slate-100 cursor-pointer flex items-center justify-center" title="Salin nomor rekening">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3a1 1 0 011-1h8a1 1 0 011 1v14a1 1 0 01-1 1h-3M9 7h5a1 1 0 011 1v14a1 1 0 01-1 1H9a1 1 0 01-1-1V8a1 1 0 011-1z" />
                  </svg>
                </button>
                <span id="copyTooltip" class="absolute -top-7 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-[10px] px-1.5 py-0.5 rounded opacity-0 pointer-events-none transition-opacity duration-200 shadow-sm whitespace-nowrap">Tersalin!</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>

  <script>
    interface InvoiceItem {
      id: string;
      description: string;
      qty: number;
      price: number;
    }

    async function initInvoiceApp() {
      // @ts-ignore
      const { default: html2pdf } = await import('html2pdf.js');
      const defaultLogoUrl = '/logo.png';
      
      let itemsList: InvoiceItem[] = [
        { id: '1', description: 'Geminithon Hackathon Production', qty: 1, price: 2500000 }
      ];

      // Referensi Elemen DOM Editor
      const inputMyName = document.getElementById('inputMyName') as HTMLInputElement;
      const inputMyProf = document.getElementById('inputMyProf') as HTMLInputElement;
      const inputInvoiceNum = document.getElementById('inputInvoiceNum') as HTMLInputElement;
      const inputClient = document.getElementById('inputClient') as HTMLInputElement;
      const inputDate = document.getElementById('inputDate') as HTMLInputElement;
      const inputLogo = document.getElementById('inputLogo') as HTMLInputElement;
      const btnResetLogo = document.getElementById('btnResetLogo') as HTMLButtonElement;
      
      // Referensi Tipe dan Nilai Admin
      const selectAdminType = document.getElementById('selectAdminType') as HTMLSelectElement;
      const inputAdminValue = document.getElementById('inputAdminValue') as HTMLInputElement;
      const labelAdminInput = document.getElementById('labelAdminInput');

      const itemsContainer = document.getElementById('itemsContainer');
      const btnAddItem = document.getElementById('btnAddItem');

      // Referensi Elemen DOM Preview Canvas
      const viewMyName = document.getElementById('viewMyName');
      const viewMyProf = document.getElementById('viewMyProf');
      const viewInvoiceNum = document.getElementById('viewInvoiceNum');
      const viewClient = document.getElementById('viewClient');
      const viewLogo = document.getElementById('viewLogo') as HTMLImageElement;
      const invoiceTableBody = document.getElementById('invoiceTableBody');
      const subTotal = document.getElementById('subTotal');
      const labelAdmin = document.getElementById('labelAdmin');
      const viewAdminFee = document.getElementById('viewAdminFee');
      const finalTotal = document.getElementById('finalTotal');
      const viewDate = document.getElementById('viewDate');
      const btnDownload = document.getElementById('btnDownload') as HTMLButtonElement;

      // Referensi DOM Fitur Copy
      const btnCopyBank = document.getElementById('btnCopyBank') as HTMLButtonElement;
      const viewBankNumber = document.getElementById('viewBankNumber');
      const copyTooltip = document.getElementById('copyTooltip');

      // Inisialisasi Tanggal hari ini secara otomatis
      const today = new Date();
      const yyyy = today.getFullYear();
      const mm = String(today.getMonth() + 1).padStart(2, '0');
      const dd = String(today.getDate()).padStart(2, '0');
      if (inputDate) inputDate.value = `${yyyy}-${mm}-${dd}`;

      const formatRupiah = (angka: number) => {
        return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(angka);
      };

      const formatTanggalIndo = (dateString: string) => {
        if (!dateString) return '-';
        const dateObj = new Date(dateString);
        return dateObj.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
      };

      // Listener Unggah Logo Temporer
      inputLogo?.addEventListener('change', () => {
        const file = inputLogo.files?.[0];
        if (file && viewLogo) {
          const blobUrl = URL.createObjectURL(file);
          viewLogo.src = blobUrl;
          btnResetLogo?.classList.remove('hidden');
        }
      });

      btnResetLogo?.addEventListener('click', () => {
        if (viewLogo && inputLogo) {
          viewLogo.src = defaultLogoUrl;
          inputLogo.value = '';
          btnResetLogo.classList.add('hidden');
        }
      });

      function renderEditorInputs() {
        if (!itemsContainer) return;
        itemsContainer.innerHTML = '';

        itemsList.forEach((item) => {
          const itemRow = document.createElement('div');
          itemRow.className = "p-3 bg-slate-50 rounded-xl border border-slate-100 space-y-2 relative group";
          itemRow.innerHTML = `
            <div class="flex justify-between items-center gap-2">
              <input type="text" data-id="${item.id}" data-field="description" value="${item.description}" placeholder="Nama Layanan/Event" class="w-full bg-white border border-slate-200 rounded-md p-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-blue-500" />
              ${itemsList.length > 1 ? `
                <button type="button" data-id="${item.id}" class="btn-delete text-red-500 hover:text-red-700 text-xs font-bold p-1 cursor-pointer">❌</button>
              ` : ''}
            </div>
            <div class="grid grid-cols-3 gap-2">
              <div>
                <label class="block text-[10px] font-medium text-slate-400 uppercase">Qty</label>
                <input type="number" data-id="${item.id}" data-field="qty" value="${item.qty}" min="1" class="w-full bg-white border border-slate-200 rounded-md p-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-blue-500" />
              </div>
              <div class="col-span-2">
                <label class="block text-[10px] font-medium text-slate-400 uppercase">Harga Satuan</label>
                <input type="number" data-id="${item.id}" data-field="price" value="${item.price}" min="0" class="w-full bg-white border border-slate-200 rounded-md p-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-blue-500" />
              </div>
            </div>
          `;
          itemsContainer.appendChild(itemRow);
        });
        bindDynamicEvents();
      }

      function updatePreview() {
        // Sinkronisasi Detail Penerbit secara Realtime
        if (viewMyName && inputMyName) viewMyName.innerText = inputMyName.value || '-';
        if (viewMyProf && inputMyProf) viewMyProf.innerText = inputMyProf.value || '-';
        if (viewInvoiceNum && inputInvoiceNum) viewInvoiceNum.innerText = inputInvoiceNum.value || '#INV-00000';
        if (viewClient && inputClient) viewClient.innerText = inputClient.value || '-';
        if (viewDate && inputDate) viewDate.innerText = `Tanggal: ${formatTanggalIndo(inputDate.value)}`;

        if (!invoiceTableBody) return;
        invoiceTableBody.innerHTML = '';

        let totalBaseAccumulator = 0;
        itemsList.forEach((item) => {
          const rowTotal = item.qty * item.price;
          totalBaseAccumulator += rowTotal;

          const tr = document.createElement('tr');
          tr.className = "divide-y divide-slate-100";
          tr.innerHTML = `
            <td class="py-3 font-medium text-slate-900 border-none">${item.description || '-'}</td>
            <td class="py-3 text-center border-none">${item.qty}</td>
            <td class="py-3 text-right border-none">${formatRupiah(item.price)}</td>
            <td class="py-3 text-right font-bold text-slate-900 border-none">${formatRupiah(rowTotal)}</td>
          `;
          invoiceTableBody.appendChild(tr);
        });

        // Logika Kalkulasi Tipe Admin
        const adminType = selectAdminType?.value || 'percent';
        const adminInputValue = parseFloat(inputAdminValue?.value) || 0;
        
        let adminFee = 0;
        let labelText = 'Biaya Admin:';

        if (adminType === 'percent') {
          adminFee = (adminInputValue / 100) * totalBaseAccumulator;
          labelText = `Biaya Admin (${adminInputValue}%):`;
        } else {
          adminFee = adminInputValue;
          labelText = `Biaya Admin (Kustom):`;
        }

        const grandTotal = totalBaseAccumulator + adminFee;

        // Render ke Live Preview Canvas
        if (subTotal) subTotal.innerText = formatRupiah(totalBaseAccumulator);
        if (labelAdmin) labelAdmin.innerText = labelText;
        if (viewAdminFee) viewAdminFee.innerText = formatRupiah(adminFee);
        if (finalTotal) finalTotal.innerText = formatRupiah(grandTotal);
      }

      function bindDynamicEvents() {
        const inputs = itemsContainer?.querySelectorAll('input');
        inputs?.forEach(input => {
          input.addEventListener('input', (e) => {
            const target = e.target as HTMLInputElement;
            const itemId = target.getAttribute('data-id');
            const field = target.getAttribute('data-field');
            const item = itemsList.find(i => i.id === itemId);
            if (item && field) {
              if (field === 'description') item.description = target.value;
              if (field === 'qty') item.qty = parseInt(target.value) || 0;
              if (field === 'price') item.price = parseInt(target.value) || 0;
              updatePreview();
            }
          });
        });

        const deleteButtons = itemsContainer?.querySelectorAll('.btn-delete');
        deleteButtons?.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const target = e.currentTarget as HTMLButtonElement;
            const itemId = target.getAttribute('data-id');
            itemsList = itemsList.filter(i => i.id !== itemId);
            renderEditorInputs();
            updatePreview();
          });
        });
      }

      btnAddItem?.addEventListener('click', () => {
        const newId = String(Date.now());
        itemsList.push({ id: newId, description: '', qty: 1, price: 0 });
        renderEditorInputs();
        updatePreview();
      });

      // Event Listener Dinamis untuk Tipe Admin
      selectAdminType?.addEventListener('change', () => {
        if (selectAdminType.value === 'percent') {
          if (labelAdminInput) labelAdminInput.innerText = 'Biaya Admin (%)';
          inputAdminValue.step = '0.1';
          inputAdminValue.value = '2.5';
        } else {
          if (labelAdminInput) labelAdminInput.innerText = 'Biaya Admin (Nominal Rp)';
          inputAdminValue.step = '1';
          inputAdminValue.value = '0';
        }
        updatePreview();
      });

      // Event Listener Aksi Salin (Copy)
      btnCopyBank?.addEventListener('click', () => {
        if (!viewBankNumber) return;
        const bankNumberText = viewBankNumber.innerText.trim();
        
        navigator.clipboard.writeText(bankNumberText).then(() => {
          if (copyTooltip) {
            copyTooltip.classList.remove('opacity-0');
            copyTooltip.classList.add('opacity-100');
            setTimeout(() => {
              copyTooltip.classList.remove('opacity-100');
              copyTooltip.classList.add('opacity-0');
            }, 1500);
          }
        }).catch(err => {
          console.error('Gagal menyalin text nomor rekening: ', err);
        });
      });

      // Event Listener Global untuk Form Input
      inputMyName?.addEventListener('input', updatePreview);
      inputMyProf?.addEventListener('input', updatePreview);
      inputInvoiceNum?.addEventListener('input', updatePreview);
      inputClient?.addEventListener('input', updatePreview);
      inputDate?.addEventListener('change', updatePreview);
      inputAdminValue?.addEventListener('input', updatePreview);

      renderEditorInputs();
      updatePreview();

      // Penanganan Ekspor PDF
      btnDownload?.addEventListener('click', () => {
        const element = document.getElementById('invoiceCanvas');
        if (!element) return;

        const clientName = inputClient?.value.replace(/\s+/g, '_') || 'Client';
        const originalText = btnDownload.innerHTML;
        btnDownload.innerHTML = '⏳ Generating PDF...';
        btnDownload.setAttribute('disabled', 'true');
        btnDownload.style.opacity = '0.6';

        const opt = {
          margin:       0.3,
          filename:     `Invoice_${clientName}.pdf`,
          image:        { type: 'jpeg', quality: 0.98 },
          html2canvas:  { 
            scale: 3, 
            useCORS: true,
            ignoreElements: (el: Element) => {
              // Menyembunyikan elemen dengan class 'ignore-pdf' atau atribut toolbar saat ekspor PDF berjalan
              if (el.classList.contains('ignore-pdf') || (el.tagName && (el.tagName.includes('-') || el.className?.toString().includes('toolbar') || el.id?.toString().includes('toolbar')))) {
                return true; 
              }
              return false;
            }
          }
        };

        html2pdf().from(element).set(opt as any).save()
          .then(() => {
            btnDownload.innerHTML = originalText;
            btnDownload.removeAttribute('disabled');
            btnDownload.style.opacity = '1';
          })
          .catch((err: any) => {
            console.error('PDF Generation Error:', err);
            btnDownload.innerHTML = originalText;
            btnDownload.removeAttribute('disabled');
            btnDownload.style.opacity = '1';
          });
      });
    }

    if (typeof window !== 'undefined') {
      initInvoiceApp();
    }
  </script>
</body>
</html>